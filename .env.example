# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth
# Secret used by Better Auth (required in production)
BETTER_AUTH_SECRET=""
# Public base URL of the app; set in production (e.g. https://app.example.com).
# Leave empty for local dev (better-auth infers it from the request).
BETTER_AUTH_URL=""
# Optional comma-separated extra trusted origins for auth POSTs/callbacks.
# Example: https://helm.devzshrc.in,https://preview.example.com
BETTER_AUTH_TRUSTED_ORIGINS=""

# Better Auth Google OAuth
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
# (locally: http://localhost:3000/api/auth/callback/google)
BETTER_AUTH_GOOGLE_CLIENT_ID=""
BETTER_AUTH_GOOGLE_CLIENT_SECRET=""

# Corsair key-encryption-key (required) — encrypts stored OAuth tokens at rest
CORSAIR_KEK=""
# Optional shared secret for inbound Corsair webhooks; when set, the Pub/Sub
# push URL must include ?token=<this value>
CORSAIR_WEBHOOK_TOKEN=""

# AI provider = Groq only
GROQ_API_KEY=""

# Secret for the scheduled-workflow cron tick (/api/cron/tick)
CRON_SECRET=""
# Embeddings (semantic search only)
GEMINI_API_KEY=""

# Drizzle
DATABASE_URL="postgresql://postgres:password@localhost:5432/superg"
